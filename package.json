{
  "name": "velkora-client",
  "version": "4.4.3",
  "description": "Launcher Minecraft",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "copy-assets": "node scripts/copy-assets.js",
    "build": "npm run copy-assets && electron-builder",
    "build:win": "npm run copy-assets && electron-builder --win",
    "build:mac": "npm run copy-assets && electron-builder --mac",
    "build:linux": "npm run copy-assets && electron-builder --linux"
  },
  "author": "Velkora Team",
  "license": "CLv1",
  "dependencies": {
    "adm-zip": "^0.5.18",
    "bootstrap-icons": "^1.13.1",
    "cors": "^2.8.6",
    "discord-rpc": "^4.0.1",
    "electron-store": "^11.0.2",
    "express": "^5.2.1",
    "idna-uts46-hx": "^6.1.7",
    "lucide": "^1.23.0",
    "minecraft-launcher-core": "^3.18.2",
    "minecraft-protocol": "^1.66.2",
    "node-fetch": "^3.3.2",
    "punycode": "^2.3.1",
    "sharp": "^0.35.3",
    "systeminformation": "^5.31.12"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "protocols": [
    {
      "name": "Minecraft Protocol",
      "schemes": [
        "minecraft"
      ]
    }
  ],
  "build": {
    "appId": "com.velkora-client.app",
    "productName": "velkora client",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "runAfterFinish": true
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png"
    }
  }
}